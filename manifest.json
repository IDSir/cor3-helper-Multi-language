{
  "manifest_version": 3,
  "name": "COR3 Helper",
  "version": "1.2.1",
  "description": "Monitor markets, expeditions, daily ops, and get timer alerts for cor3.gg.",
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "sidePanel"
  ],
  "side_panel": {
    "default_path": "popup.html"
  },
  "host_permissions": [
    "https://cor3.gg/*",
    "https://os.cor3.gg/*",
    "https://svc-corie.cor3.gg/*",
    "https://raw.githubusercontent.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://cor3.gg/*",
        "https://os.cor3.gg/*"
      ],
      "js": [
        "content-early.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://cor3.gg/*",
        "https://os.cor3.gg/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "COR3 Helper"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "ws-interceptor.js",
        "decrypt-solver.js",
        "daily-hack-solver.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
